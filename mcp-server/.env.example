# MySQL warehouse (shared with both agents)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=risk_db

# Ground truth source for compute_metrics (pom_acr | column)
GROUND_TRUTH_SOURCE=pom_acr

# Session persistence directory (config-agent memory)
SESSIONS_DIR=./sessions

# fraud-analysis-agent base URL (used by fetch_fraud_report tool)
FRAUD_AGENT_URL=http://fraud-analysis-agent:8080

# MCP server port
MCP_SERVER_PORT=8000
