# LLM (VNG MAAS / OpenAI-compatible). Leave USE_REAL_LLM unset to use MockLLM (CI/tests/demo).
USE_REAL_LLM=
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Default fallback model + per-role overrides. intake/build are the reasoning nodes.
LLM_MODEL=minimax/minimax-m2.5
LLM_MODEL_INTAKE=minimax/minimax-m2.5
LLM_MODEL_CLARIFY=google/gemma-4-31b-it
LLM_MODEL_BUILD=minimax/minimax-m2.5

# Hosted MySQL (config write target). Leave MYSQL_HOST unset to use MockConfigStore.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=risk_db
MYSQL_USER=root
MYSQL_PASSWORD=

# fraud-analysis-agent base URL (for pull-by-run_id). Default points at local dev.
FRAUD_AGENT_URL=http://localhost:8000
